---
import Layout from '../layouts/Layout.astro';

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": "https://piedrascanning.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "La Empresa",
      "item": "https://piedrascanning.com/la-empresa"
    }
  ]
};
---

<Layout 
  title="La Empresa | 70 Años de Historia | Piedras Canning" 
  description="Conocé la historia de Piedras Canning: más de 70 años de tradición familiar y 10 años en el sector de Canning ofreciendo piedras naturales y colocaciones artesanales."
  jsonLd={breadcrumbSchema}
>
  <div class="empresa-page">
    <!-- Hero Banner -->
    <section class="empresa-hero">
      <div class="hero-overlay"></div>
      <div class="hero-content">
        <h1 class="hero-title">Nuestra Historia</h1>
      </div>
    </section>

    <!-- Subheader Text -->
    <section class="intro-section">
      <div class="intro-container">
        <p class="intro-text">
          Piedras Canning, con 70 años de historia, ofrece piedras naturales y colocaciones artesanales de calidad.
        </p>
      </div>
    </section>

    <!-- Main Content Blocks -->
    <div class="content-sections">
      <!-- Compromiso y Calidad -->
      <section class="feature-block">
        <div class="feature-container">
          <div class="feature-image-col">
            <img 
              src="/images/piedras-mar.jpg" 
              alt="Compromiso y Calidad - Piedras Canning" 
              class="feature-img"
              width="540"
              height="540"
              loading="eager"
              decoding="async"
            />
          </div>

          <div class="feature-text-col">
            <h2 class="feature-title">Compromiso y Calidad</h2>
            <p class="feature-description">
              En Piedras Canning, somos una empresa con 70 años de historia y más de una década en el sector de Canning. Nos especializamos en la comercialización de piedras naturales y en la fabricación de atérmicos artesanales para piscinas. Ofrecemos una amplia variedad de productos y un servicio de colocación artesanal de primer nivel, garantizando la excelencia en calidad y mano de obra en cada proyecto, desde frentes de múrete hasta entradas vehiculares.
            </p>
          </div>
        </div>
      </section>

      <!-- Sostenibilidad -->
      <section class="feature-block reverse">
        <div class="feature-container">
          <div class="feature-text-col">
            <h2 class="feature-title">Sostenibilidad</h2>
            <p class="feature-description">
              En Piedras Canning, valoramos la calidad y la tradición, ofreciendo productos naturales y artesanales que respetan el medio ambiente y promueven la durabilidad.
            </p>
            <div class="cta-wrapper">
              <a href="/#proyectos" class="btn-proyectos">
                Ver proyectos
              </a>
            </div>
          </div>
          <div class="feature-image-col">
            <img 
              src="/images/piedras-mar.jpg" 
              alt="Sostenibilidad y Piedras Naturales - Piedras Canning" 
              class="feature-img"
              width="540"
              height="540"
              loading="lazy"
              decoding="async"
            />

          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  .empresa-page {
    width: 100%;
    background-color: #ffffff;
  }

  /* Hero Banner */
  .empresa-hero {
    position: relative;
    width: 100%;
    height: 320px;
    background-image: url('/images/nuestra-historia-bg.jpg');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.35);
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    padding: 0 20px;
  }

  .hero-title {
    font-family: var(--font-sans);
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    font-weight: 700;
    color: #ffffff;
    letter-spacing: -0.01em;
    margin: 0;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  /* Intro Section */
  .intro-section {
    padding: 60px 24px 40px 24px;
    text-align: center;
  }

  .intro-container {
    max-width: 780px;
    margin: 0 auto;
  }

  .intro-text {
    font-family: var(--font-sans);
    font-size: clamp(1.1rem, 2.2vw, 1.25rem);
    font-weight: 600;
    color: var(--color-text-main, #1f1f24);
    line-height: 1.5;
    margin: 0;
  }

  /* Content Feature Blocks */
  .content-sections {
    display: flex;
    flex-direction: column;
    gap: 80px;
    padding-bottom: 100px;
  }

  .feature-block {
    width: 100%;
  }

  .feature-container {
    max-width: var(--max-width, 1280px);
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .feature-image-col {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .feature-img {
    width: 100%;
    max-width: 540px;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    display: block;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  .feature-text-col {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
  }

  .feature-title {
    font-family: var(--font-sans);
    font-size: clamp(1.8rem, 3.2vw, 2.5rem);
    font-weight: 700;
    color: var(--color-primary, #a02a27);
    margin: 0 0 20px 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
  }

  .feature-description {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    color: var(--color-text-muted, #55555e);
    line-height: 1.65;
    margin: 0;
  }

  .cta-wrapper {
    margin-top: 28px;
  }

  .btn-proyectos {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary, #a02a27);
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 12px 32px;
    border-radius: 6px;
    transition: all 0.25s ease;
    box-shadow: none;
  }

  .btn-proyectos:hover {
    background-color: var(--color-primary-dark, #801e1c);
    transform: translateY(-2px);
    box-shadow: none;
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .empresa-hero {
      height: 240px;
    }

    .intro-section {
      padding: 40px 20px 20px 20px;
    }

    .content-sections {
      gap: 50px;
      padding-bottom: 60px;
    }

    .feature-container {
      grid-template-columns: 1fr;
      gap: 32px;
      padding: 0 24px;
    }

    .feature-block.reverse .feature-container {
      display: flex;
      flex-direction: column-reverse;
    }

    .feature-img {
      max-width: 100%;
      aspect-ratio: 4 / 3;
    }
  }
</style>
