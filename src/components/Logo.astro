---
interface Props {
  className?: string;
  height?: number;
}

const { className = "", height = 73 } = Astro.props;
---

<div class={`logo-wrapper ${className}`}>
  <picture>
    <source srcset="/images/logo.webp" type="image/webp" />
    <img 
      src="/images/logo.png" 
      alt="Piedras Canning" 
      class="logo-img"
      width="220"
      height={height}
      style={`height: ${height}px; width: auto;`}
      loading="eager"
      decoding="async"
    />
  </picture>
</div>

<style>
  .logo-wrapper {
    display: inline-flex;
    align-items: center;
    user-select: none;
  }

  .logo-img {
    width: auto;
    object-fit: contain;
    transition: transform 0.25s ease;
  }

  .logo-wrapper:hover .logo-img {
    transform: scale(1.03);
  }

  @media (max-width: 640px) {
    .logo-img {
      height: 58px !important;
    }
  }
</style>
