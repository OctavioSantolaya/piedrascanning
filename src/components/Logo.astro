---
interface Props {
  className?: string;
  height?: number;
}

const { className = "", height = 73 } = Astro.props;
---

<div class={`logo-wrapper ${className}`}>
  <img 
    src="/images/logo.png" 
    alt="Piedras Canning - Logo" 
    class="logo-img"
    style={`height: ${height}px;`}
    loading="eager"
    decoding="async"
  />
</div>

<style>
  .logo-wrapper {
    display: inline-flex;
    align-items: center;
    user-select: none;
  }

  .logo-img {
    width: auto;
    object-fit: contain;
    transition: transform 0.25s ease;
  }

  .logo-wrapper:hover .logo-img {
    transform: scale(1.03);
  }

  @media (max-width: 640px) {
    .logo-img {
      height: 58px !important;
    }
  }
</style>
