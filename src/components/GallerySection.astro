  { src: "/images/galeria/img-2.png", alt: "Proyecto Piedras Canning 2" },
  { src: "/images/galeria/img-3.jpg", alt: "Proyecto Piedras Canning 3" },
  { src: "/images/galeria/img-4.jpg", alt: "Proyecto Piedras Canning 4" },
  { src: "/images/galeria/img-5.png", alt: "Proyecto Piedras Canning 5" },
  { src: "/images/galeria/img-6.png", alt: "Proyecto Piedras Canning 6" },
  { src: "/images/galeria/img-7.jpg", alt: "Proyecto Piedras Canning 7" },
  { src: "/images/galeria/img-8.jpg", alt: "Proyecto Piedras Canning 8" },
  { src: "/images/galeria/img-9.png", alt: "Proyecto Piedras Canning 9" },
  { src: "/images/galeria/img-10.jpg", alt: "Proyecto Piedras Canning 10" },
  { src: "/images/galeria/img-11.png", alt: "Proyecto Piedras Canning 11" },
  { src: "/images/galeria/img-12.jpg", alt: "Proyecto Piedras Canning 12" },
  { src: "/images/galeria/img-13.jpg", alt: "Proyecto Piedras Canning 13" },
