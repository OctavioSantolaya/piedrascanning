---
interface Props {
  address?: string;
  mapQueryUrl?: string;
}

const {
  address = "Autopista Ezeiza Cañuelas, Bajada, colectora km 41, Tristán Suárez, Provincia de Buenos Aires, Argentina",
  mapQueryUrl = "https://maps.google.com/maps?q=Autopista%20Ezeiza%20Ca%C3%B1uelas%2C%20colectora%20km%2041%2C%20Trist%C3%A1n%20Su%C3%A1rez%2C%20Provincia%20de%20Buenos%20Aires%2C%20Argentina&t=&z=14&ie=UTF8&iwloc=&output=embed"
} = Astro.props;
---

<section class="map-section">
  <div class="map-container">
    <div class="map-wrapper">
      <iframe
        title="Ubicación Piedras Canning"
        src={mapQueryUrl}
        width="100%"
        height="480"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="map-iframe"
      ></iframe>
    </div>
  </div>
</section>

<style>
  .map-section {
    width: 100%;
    background-color: #ffffff;
    padding: 60px 0 80px 0;
  }

  .map-container {
    max-width: var(--max-width, 1280px);
    margin: 0 auto;
    padding: 0 28px;
  }

  .map-wrapper {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e5e5;
    background-color: #f8f8f8;
  }

  .map-iframe {
    width: 100%;
    height: 480px;
    display: block;
  }

  @media (max-width: 768px) {
    .map-section {
      padding: 40px 0 60px 0;
    }

    .map-container {
      padding: 0 16px;
    }

    .map-iframe {
      height: 360px;
    }
  }
</style>
