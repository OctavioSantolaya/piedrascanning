---
interface Props {
  address?: string;
  mapQueryUrl?: string;
}

const {
  address = "Autopista Ezeiza Cañuelas, Bajada, colectora km 41, Tristán Suárez, Provincia de Buenos Aires, Argentina",
  mapQueryUrl = "https://maps.google.com/maps?q=Piedras%20Canning&t=&z=15&ie=UTF8&iwloc=&output=embed"
} = Astro.props;
---

<section class="map-section">
  <div class="map-container">
    <div class="map-wrapper">
      <iframe
        title="Ubicación Piedras Canning"
        data-src={mapQueryUrl}
        width="100%"
        height="480"
        style="border:0;"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        class="map-iframe"
        id="map-iframe"
      ></iframe>
    </div>
  </div>
</section>

<script>
  const iframe = document.getElementById('map-iframe') as HTMLIFrameElement;
  if (iframe && iframe.dataset.src) {
    const loadMap = () => {
      if (!iframe.src && iframe.dataset.src) {
        iframe.src = iframe.dataset.src;
      }
    };

    if ('IntersectionObserver' in window) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            loadMap();
            observer.disconnect();
          }
        });
      }, { rootMargin: '300px' });
      observer.observe(iframe);
    } else {
      loadMap();
    }
  }
</script>

<style>
  .map-section {
    width: 100%;
    background-color: #ffffff;
    padding: 60px 0 80px 0;
  }

  .map-container {
    max-width: var(--max-width, 1280px);
    margin: 0 auto;
    padding: 0 28px;
  }

  .map-wrapper {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e5e5;
    background-color: #f8f8f8;
  }

  .map-iframe {
    width: 100%;
    height: 480px;
    display: block;
  }

  @media (max-width: 768px) {
    .map-section {
      padding: 40px 0 60px 0;
    }

    .map-container {
      padding: 0 16px;
    }

    .map-iframe {
      height: 360px;
    }
  }
</style>
