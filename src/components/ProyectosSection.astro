---
import { getCollection } from 'astro:content';

const allProyectos = await getCollection('proyectos');
const proyectos = allProyectos
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
  .slice(0, 3);
---

<section id="proyectos" class="proyectos-section">
  <div class="proyectos-container">
    <h2 class="section-title">Obras y proyectos</h2>
    
    <div class="proyectos-grid">
      {proyectos.map((proyecto) => (
        <article class="proyecto-card">
          <a href={`/proyectos/${proyecto.id}`} class="card-link">
            <div class="image-wrapper">
              <picture>
                <source srcset={proyecto.data.featuredImage.replace(/\.(jpg|jpeg|png)$/i, '.webp')} type="image/webp" />
                <img 
                  src={proyecto.data.featuredImage} 
                  alt={`${proyecto.data.title} - Piedras Canning`} 
                  class="proyecto-img" 
                  width="400"
                  height="300"
                  loading="lazy"
                  decoding="async"
                />
              </picture>
            </div>
            <div class="card-content">
              <h3 class="proyecto-title">{proyecto.data.title}</h3>
              {proyecto.data.description && (
                <p class="proyecto-description">{proyecto.data.description}</p>
              )}
              <div class="read-more">
                LEER MÁS ➔
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <div class="see-all-wrapper">
      <a href="/proyectos" class="btn-all-proyectos">
        Ver todos los proyectos
      </a>
    </div>
  </div>
</section>

<style>
  .proyectos-section {
    width: 100%;
    background-color: #ffffff;
    padding: 80px 0;
  }

  .proyectos-container {
    max-width: var(--max-width, 1280px);
    margin: 0 auto;
    padding: 0 28px;
  }

  .section-title {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 3.5vw, 2.6rem);
    font-weight: 700;
    color: #111111;
    text-align: center;
    margin-bottom: 54px;
    letter-spacing: -0.01em;
  }

  .proyectos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 36px 32px;
  }

  .proyecto-card {
    display: flex;
    flex-direction: column;
    background-color: #ffffff;
  }

  .card-link {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .proyecto-card:hover .proyecto-img {
    transform: scale(1.03);
  }

  .image-wrapper {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .proyecto-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .card-content {
    padding-top: 18px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .proyecto-title {
    font-family: var(--font-sans);
    font-size: 1.3rem;
    font-weight: 700;
    color: #111111;
    line-height: 1.3;
    margin: 0;
    letter-spacing: -0.01em;
    transition: color 0.2s ease;
  }

  .proyecto-card:hover .proyecto-title {
    color: var(--color-primary, #a02a27);
  }

  .proyecto-description {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    color: #555555;
    line-height: 1.5;
    margin-top: 10px;
    margin-bottom: 12px;
    flex: 1;
  }

  .read-more {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 800;
    color: #111111;
    letter-spacing: 0.03em;
    margin-top: auto;
    transition: color 0.2s ease;
  }

  .proyecto-card:hover .read-more {
    color: var(--color-primary, #a02a27);
  }

  .see-all-wrapper {
    display: flex;
    justify-content: center;
    margin-top: 50px;
  }

  .btn-all-proyectos {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary, #a02a27);
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    padding: 12px 32px;
    border-radius: 6px;
    transition: all 0.25s ease;

  }

  .btn-all-proyectos:hover {
    background-color: var(--color-primary-dark, #801e1c);
    transform: translateY(-2px);
  }

  @media (max-width: 992px) {
    .proyectos-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 640px) {
    .proyectos-section {
      padding: 50px 0;
    }

    .section-title {
      margin-bottom: 36px;
    }

    .proyectos-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
