---
interface Props {
  titleLine1?: string;
  titleLine2?: string;
  btnText?: string;
  btnLink?: string;
  bgImage?: string;
}

const {
  titleLine1 = "Conoce más",
  titleLine2 = "sobre nosotros",
  btnText = "Ver más",
  btnLink = "/la-empresa",
  bgImage = "/images/sobre-nosotros-bg.jpg"
} = Astro.props;
---

<section class="about-banner" style={`background-image: url('${bgImage}');`}>
  <div class="banner-overlay"></div>
  <div class="banner-content">
    <h2 class="banner-title">
      <span>{titleLine1}</span>
      <span>{titleLine2}</span>
    </h2>
    <a href={btnLink} class="btn-ver-mas">
      {btnText}
    </a>
  </div>
</section>

<style>
  .about-banner {
    position: relative;
    width: 100%;
    min-height: 440px;
    height: 55vh;
    max-height: 540px;
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #ffffff;
    overflow: hidden;
  }

  /* Subtle Dark Overlay */
  .banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.22);
    z-index: 1;
  }

  .banner-content {
    position: relative;
    z-index: 2;
    max-width: var(--max-width, 1280px);
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

  .banner-title {
    font-family: var(--font-sans);
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    font-weight: 500;
    color: #ffffff;
    line-height: 1.15;
    letter-spacing: -0.015em;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.25);
  }

  .btn-ver-mas {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary, #a02a27);
    color: #ffffff;
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 500;
    padding: 12px 36px;
    border-radius: 6px;
    letter-spacing: 0.01em;
    transition: all 0.25s ease;
    box-shadow: none;
  }

  .btn-ver-mas:hover {
    background-color: var(--color-primary-dark, #801e1c);
    transform: translateY(-2px);
    box-shadow: none;
  }

  @media (max-width: 640px) {
    .about-banner {
      min-height: 340px;
      height: 45vh;
    }

    .banner-content {
      gap: 20px;
    }

    .btn-ver-mas {
      padding: 10px 28px;
      font-size: 0.9rem;
    }
  }
</style>
